{
  "extends": "expo/tsconfig.base",
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts", "nativewind-env.d.ts"],
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@vortex/api": ["../../packages/api/src/index.ts"],
      "@vortex/api/*": ["../../packages/api/src/*"],
      "@vortex/config": ["../../packages/config/src/index.ts"],
      "@vortex/config/*": ["../../packages/config/src/*"],
      "@vortex/hooks": ["../../packages/hooks/src/index.ts"],
      "@vortex/hooks/*": ["../../packages/hooks/src/*"],
      "@vortex/types": ["../../packages/types/src/index.ts"],
      "@vortex/types/*": ["../../packages/types/src/*"],
      "@vortex/ui": ["../../packages/ui/src/index.ts"],
      "@vortex/ui/*": ["../../packages/ui/src/*"],
      "@vortex/utils": ["../../packages/utils/src/index.ts"],
      "@vortex/utils/*": ["../../packages/utils/src/*"],
      "@vortex/validation": ["../../packages/validation/src/index.ts"],
      "@vortex/validation/*": ["../../packages/validation/src/*"]
    }
  }
}
