# Base URL of the sheger-store-backend NestJS API.
# On a physical device/simulator "localhost" refers to the device itself, not your
# dev machine — use your machine's LAN IP (e.g. http://192.168.1.20:3000) when testing
# on real hardware. Expo inlines EXPO_PUBLIC_* vars into the JS bundle automatically.
EXPO_PUBLIC_API_URL=http://localhost:3000
